DJANGO_ENVIRONMENT=development
DJANGO_SECRET_KEY=replace-me
# Production may use DJANGO_SECRET_KEY_FILE=/run/secrets/django_secret_key instead.
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_PUBLIC_BASE_URL=http://localhost:8000
DJANGO_DISABLE_PASSWORD_VALIDATORS=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SESSION_EXPIRE_AT_BROWSER_CLOSE=1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
# Set only behind a trusted proxy that strips and replaces X-Forwarded-Proto.
DJANGO_TRUST_X_FORWARDED_PROTO=0
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_TRUSTED_PROXY_IPS=
DJANGO_TRUSTED_PROXY_COUNT=1
DATABASE_URL=postgres://pos_saas:pos_saas@127.0.0.1:55432/pos_saas
# Keep this stable and separate from DJANGO_SECRET_KEY. During rotation, retain old
# keys (comma-separated) until every retained audit event using them has expired.
DJANGO_AUDIT_LOG_HMAC_KEY=
DJANGO_AUDIT_LOG_HMAC_KEY_FALLBACKS=
DJANGO_DATABASE_CONNECT_TIMEOUT=10
# Zero disables the timeout. Set finite production values after measuring reports.
DJANGO_DATABASE_STATEMENT_TIMEOUT_MS=0
DJANGO_DATABASE_LOCK_TIMEOUT_MS=0
# Enable for PgBouncer transaction-pooling mode.
DJANGO_DATABASE_DISABLE_SERVER_SIDE_CURSORS=0
# Production requires shared Redis so rate limits work across all workers.
# DJANGO_CACHE_URL=redis://127.0.0.1:6379/1
DJANGO_CACHE_KEY_PREFIX=pos_saas
DJANGO_RATE_LOGIN_IP=20/15m
DJANGO_RATE_LOGIN_IDENTITY=5/15m
DJANGO_RATE_SIGNUP=10/h
DJANGO_RATE_INVITATION=20/h
DJANGO_RATE_INVITATION_TOKEN=10/15m
DJANGO_RATE_VERIFICATION_RESEND=3/h
DJANGO_LOG_LEVEL=INFO
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=POS SaaS <no-reply@pos-saas.local>
DJANGO_EMAIL_TIMEOUT=10
# Optional custom-backend override. SendGrid SMTP enables outbound delivery automatically.
# DJANGO_OUTBOUND_EMAIL_ENABLED=1

# SendGrid SMTP delivery. Set SENDGRID_API_KEY in production/staging to enable it.
# DEFAULT_FROM_EMAIL must be a verified SendGrid sender or domain identity.
SENDGRID_API_KEY=
SENDGRID_EMAIL_HOST=smtp.sendgrid.net
SENDGRID_EMAIL_PORT=587
SENDGRID_EMAIL_HOST_USER=apikey
SENDGRID_EMAIL_USE_TLS=1
