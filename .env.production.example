# Configuration only. Keep this file free of secret values and copy it outside the repository.
POS_SAAS_IMAGE=registry.example.com/pos-saas@sha256:replace-with-release-digest
SECRETS_DIR=/srv/pos-saas/secrets
WEB_PORT=8000

DJANGO_ENVIRONMENT=production
DJANGO_DEBUG=0
DJANGO_SECRET_KEY_FILE=/run/secrets/django_secret_key
DJANGO_AUDIT_LOG_HMAC_KEY_FILE=/run/secrets/audit_log_hmac_key
DJANGO_ALLOWED_HOSTS=pos.example.com
DJANGO_PUBLIC_BASE_URL=https://pos.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_TRUST_X_FORWARDED_PROTO=1
# Must be the address Docker sees for the host reverse proxy.
DJANGO_TRUSTED_PROXY_IPS=172.17.0.1
DJANGO_TRUSTED_PROXY_COUNT=1

# The secret file must contain a URL using sslmode=verify-full and the mounted CA path.
DATABASE_URL_FILE=/run/secrets/database_url
DJANGO_CACHE_URL_FILE=/run/secrets/redis_url
DJANGO_CACHE_KEY_PREFIX=pos_saas_production
DJANGO_DATABASE_CONNECT_TIMEOUT=10
DJANGO_DATABASE_STATEMENT_TIMEOUT_MS=30000
DJANGO_DATABASE_LOCK_TIMEOUT_MS=5000

SENDGRID_API_KEY_FILE=/run/secrets/sendgrid_api_key
DJANGO_DEFAULT_FROM_EMAIL=POS SaaS <no-reply@example.com>
DJANGO_LOG_LEVEL=INFO
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=30
